# Entry password for the demo gate (hint: our birth year).
# Copy this file to `.env` and set your own value. `.env` is gitignored.
VITE_GATE_PASSWORD=your-password-here

# Only needed if you later wire up real Supabase auth (currently unused).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
